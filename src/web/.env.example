# Vite carrega variáveis VITE_* automaticamente. Copie pra `.env.local`.

# Cloudflare Turnstile site key (público — pode commitar se quiser).
# Pegar em https://dash.cloudflare.com → Turnstile → criar widget pra app.rjmais.com.
# Em dev, pode usar a chave de teste abaixo (sempre passa):
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# (opcional) Sentry DSN do frontend
# VITE_SENTRY_DSN=
